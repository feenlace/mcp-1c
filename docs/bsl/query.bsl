// Обработчик POST /query
// Выполняет запрос на языке запросов 1С (только SELECT/ВЫБРАТЬ).
//
// Тело запроса: JSON {"query": "ВЫБРАТЬ ...", "limit": 100}
// Ответ: JSON {"columns": [...], "rows": [[...], ...], "total": N, "truncated": true/false}
//
// БЕЗОПАСНОСТЬ: Сервер-сторона дополнительно проверяет,
// что запрос начинается с ВЫБРАТЬ/SELECT.
//
// ПРИМЕЧАНИЕ: Вспомогательные функции ОтветJSON, ОтветОшибка, РазобратьJSON, СформироватьJSON,
// НайтиМетаданныеПоТипуИИмени и ПреобразоватьЗначениеПараметра определены в основном модуле
// HTTP-сервиса (Module.bsl).

Функция ЗапросPOST(Запрос)
    Параметры = РазобратьJSON(Запрос.ПолучитьТелоКакСтроку());

    ТекстЗапроса = Параметры.query;
    Лимит = 100;
    Если Параметры.Свойство("limit") И Параметры.limit > 0 Тогда
        Лимит = Мин(Параметры.limit, 1000);
    КонецЕсли;

    Префикс = ВРег(СокрЛП(Лев(ТекстЗапроса, 10)));
    Если Лев(Префикс, 7) <> "ВЫБРАТЬ" И Лев(Префикс, 6) <> "SELECT" Тогда
        Возврат ОтветОшибка(400, "Only SELECT queries allowed");
    КонецЕсли;

    Попытка
        Запрос1С = Новый Запрос(ТекстЗапроса);

        Если Параметры.Свойство("parameters") И ТипЗнч(Параметры.parameters) = Тип("Структура") Тогда
            Для Каждого КлючИЗначение Из Параметры.parameters Цикл
                // ПреобразоватьЗначениеПараметра конвертирует ISO-строки дат → тип Дата
                Запрос1С.УстановитьПараметр(КлючИЗначение.Ключ, ПреобразоватьЗначениеПараметра(КлючИЗначение.Значение));
            КонецЦикла;
        КонецЕсли;

        РезультатЗапроса = Запрос1С.Выполнить();
    Исключение
        Возврат ОтветОшибка(400, ОписаниеОшибки());
    КонецПопытки;

    Выборка = РезультатЗапроса.Выбрать();

    Колонки = Новый Массив;
    Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
        Колонки.Добавить(Колонка.Имя);
    КонецЦикла;

    Строки = Новый Массив;
    Счетчик = 0;
    Усечено = Ложь;
    Пока Выборка.Следующий() Цикл
        Если Счетчик >= Лимит Тогда
            Усечено = Истина;
            Прервать;
        КонецЕсли;
        Строка = Новый Массив;
        Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
            Строка.Добавить(ПривестиЗначениеКJSON(Выборка[Колонка.Имя]));
        КонецЦикла;
        Строки.Добавить(Строка);
        Счетчик = Счетчик + 1;
    КонецЦикла;

    Результат = Новый Структура;
    Результат.Вставить("columns", Колонки);
    Результат.Вставить("rows", Строки);
    Результат.Вставить("total", Счетчик);
    Результат.Вставить("truncated", Усечено);

    Возврат ОтветJSON(Результат);
КонецФункции
