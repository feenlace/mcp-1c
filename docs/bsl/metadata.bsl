// Обработчик GET /metadata
// Возвращает дерево метаданных конфигурации: все типы объектов и их имена.
//
// Ответ: JSON-объект, где ключ — тип метаданных, значение — массив имён.
// Пример: {"Справочники": ["Контрагенты", "Номенклатура"], "Документы": [...]}
//
// ПРИМЕЧАНИЕ: Вспомогательные функции ОтветJSON, ОтветОшибка, РазобратьJSON, СформироватьJSON
// и НайтиМетаданныеПоТипуИИмени определены в основном модуле HTTP-сервиса (Module.bsl).

Функция МетаданныеGET(Запрос)
    Результат = Новый Структура;

    ИменаКоллекций = Новый Массив;
    ИменаКоллекций.Добавить("Справочники");
    ИменаКоллекций.Добавить("Документы");
    ИменаКоллекций.Добавить("Перечисления");
    ИменаКоллекций.Добавить("Обработки");
    ИменаКоллекций.Добавить("Отчеты");
    ИменаКоллекций.Добавить("РегистрыСведений");
    ИменаКоллекций.Добавить("РегистрыНакопления");
    ИменаКоллекций.Добавить("РегистрыБухгалтерии");
    ИменаКоллекций.Добавить("РегистрыРасчета");
    ИменаКоллекций.Добавить("ПланыСчетов");
    ИменаКоллекций.Добавить("ПланыВидовХарактеристик");
    ИменаКоллекций.Добавить("ПланыВидовРасчета");
    ИменаКоллекций.Добавить("ПланыОбмена");
    ИменаКоллекций.Добавить("БизнесПроцессы");
    ИменаКоллекций.Добавить("Задачи");
    ИменаКоллекций.Добавить("ОпределяемыеТипы");
    ИменаКоллекций.Добавить("ЖурналыДокументов");
    ИменаКоллекций.Добавить("Константы");
    ИменаКоллекций.Добавить("ОбщиеМодули");
    ИменаКоллекций.Добавить("ОбщиеФормы");
    ИменаКоллекций.Добавить("ОбщиеКоманды");
    ИменаКоллекций.Добавить("ОбщиеМакеты");
    ИменаКоллекций.Добавить("Роли");
    ИменаКоллекций.Добавить("Подсистемы");
    ИменаКоллекций.Добавить("РегулярныеЗадания");
    ИменаКоллекций.Добавить("ВебСервисы");
    ИменаКоллекций.Добавить("HTTPСервисы");

    Для Каждого ИмяКоллекции Из ИменаКоллекций Цикл
        Попытка
            Коллекция = Метаданные[ИмяКоллекции];
            Имена = Новый Массив;
            Для Каждого ОбъектМетаданных Из Коллекция Цикл
                Имена.Добавить(ОбъектМетаданных.Имя);
            КонецЦикла;
            Результат.Вставить(ИмяКоллекции, Имена);
        Исключение
            Продолжить;
        КонецПопытки;
    КонецЦикла;

    Возврат ОтветJSON(Результат);
КонецФункции
