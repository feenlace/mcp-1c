// Обработчик GET /object/{type}/{name}
// Возвращает структуру объекта метаданных: реквизиты, табличные части, измерения, ресурсы,
// а для перечислений — список значений.
//
// URL параметры:
//   type — тип объекта: Catalog, Document, AccumulationRegister, InformationRegister,
//          AccountingRegister, Enum, DataProcessor, Report, ChartOfAccounts,
//          ChartOfCharacteristicTypes, ChartOfCalculationTypes, ExchangePlan,
//          BusinessProcess, Task
//   name — имя объекта метаданных
//
// Ответ: JSON-объект с полями name, synonym, attributes, tabularParts, dimensions, resources, values
//
// ПРИМЕЧАНИЕ: Вспомогательные функции ОтветJSON, ОтветОшибка, РазобратьJSON, СформироватьJSON,
// ЕстьКоллекция и НайтиМетаданныеПоТипуИИмени определены в основном модуле HTTP-сервиса (Module.bsl).

Функция ОбъектGET(Запрос)
    ТипОбъекта = Запрос.ПараметрыURL["type"];
    ИмяОбъекта = Запрос.ПараметрыURL["name"];

    ОбъектМД = НайтиМетаданныеПоТипуИИмени(ТипОбъекта, ИмяОбъекта);
    Если ОбъектМД = Неопределено Тогда
        Возврат ОтветОшибка(404, "Object not found");
    КонецЕсли;

    Результат = Новый Структура;
    Результат.Вставить("name", ОбъектМД.Имя);
    Результат.Вставить("synonym", ОбъектМД.Синоним);

    Реквизиты = Новый Массив;
    Если ЕстьКоллекция(ОбъектМД, "Реквизиты") Тогда
        Для Каждого Реквизит Из ОбъектМД.Реквизиты Цикл
            ОписаниеРеквизита = Новый Структура;
            ОписаниеРеквизита.Вставить("name", Реквизит.Имя);
            ОписаниеРеквизита.Вставить("synonym", Реквизит.Синоним);
            ОписаниеРеквизита.Вставить("type", Строка(Реквизит.Тип));
            Реквизиты.Добавить(ОписаниеРеквизита);
        КонецЦикла;
    КонецЕсли;
    Результат.Вставить("attributes", Реквизиты);

    Если ЕстьКоллекция(ОбъектМД, "ТабличныеЧасти") Тогда
        ТЧ = Новый Массив;
        Для Каждого ТабличнаяЧасть Из ОбъектМД.ТабличныеЧасти Цикл
            ОписаниеТЧ = Новый Структура;
            ОписаниеТЧ.Вставить("name", ТабличнаяЧасть.Имя);
            РеквизитыТЧ = Новый Массив;
            Для Каждого Реквизит Из ТабличнаяЧасть.Реквизиты Цикл
                Описание = Новый Структура;
                Описание.Вставить("name", Реквизит.Имя);
                Описание.Вставить("synonym", Реквизит.Синоним);
                Описание.Вставить("type", Строка(Реквизит.Тип));
                РеквизитыТЧ.Добавить(Описание);
            КонецЦикла;
            ОписаниеТЧ.Вставить("attributes", РеквизитыТЧ);
            ТЧ.Добавить(ОписаниеТЧ);
        КонецЦикла;
        Результат.Вставить("tabularParts", ТЧ);
    КонецЕсли;

    Если ЕстьКоллекция(ОбъектМД, "Измерения") Тогда
        Измерения = Новый Массив;
        Для Каждого Измерение Из ОбъектМД.Измерения Цикл
            Описание = Новый Структура;
            Описание.Вставить("name", Измерение.Имя);
            Описание.Вставить("synonym", Измерение.Синоним);
            Описание.Вставить("type", Строка(Измерение.Тип));
            Измерения.Добавить(Описание);
        КонецЦикла;
        Результат.Вставить("dimensions", Измерения);
    КонецЕсли;

    Если ЕстьКоллекция(ОбъектМД, "Ресурсы") Тогда
        Ресурсы = Новый Массив;
        Для Каждого Ресурс Из ОбъектМД.Ресурсы Цикл
            Описание = Новый Структура;
            Описание.Вставить("name", Ресурс.Имя);
            Описание.Вставить("synonym", Ресурс.Синоним);
            Описание.Вставить("type", Строка(Ресурс.Тип));
            Ресурсы.Добавить(Описание);
        КонецЦикла;
        Результат.Вставить("resources", Ресурсы);
    КонецЕсли;

    Если ЕстьКоллекция(ОбъектМД, "ЗначенияПеречисления") Тогда
        Значения = Новый Массив;
        Для Каждого Значение Из ОбъектМД.ЗначенияПеречисления Цикл
            Описание = Новый Структура;
            Описание.Вставить("name", Значение.Имя);
            Описание.Вставить("synonym", Значение.Синоним);
            Описание.Вставить("comment", Значение.Комментарий);
            Значения.Добавить(Описание);
        КонецЦикла;
        Результат.Вставить("values", Значения);
    КонецЕсли;

    Возврат ОтветJSON(Результат);
КонецФункции
